{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "CrossForge default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:allow-execute",
    "shell:allow-open",
    "shell:allow-stdin-write",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir"
  ]
}
